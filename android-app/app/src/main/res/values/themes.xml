<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AUTOPAD" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryContainer">@color/primary_bg</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/btn_text</item>
        <item name="colorOnSecondary">@color/primary_text</item>
        <item name="android:colorBackground">@color/primary_bg</item>
        <item name="colorSurface">@color/secondary_bg</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowBackground">@color/primary_bg</item>
    </style>

    <style name="CardStyle">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="AccentButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/divider</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="TrackpadButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/tertiary_bg</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="KeyboardKey" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/key_bg</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="textSize">14sp</item>
    </style>

    <style name="ModifierKey" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/modifier_key_bg</item>
        <item name="android:textColor">@color/accent_purple</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <style name="SpecialKey" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/special_key_bg</item>
        <item name="android:textColor">@color/success_green</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <style name="MediaButton" parent="Widget.Material3.Button.IconButton">
        <item name="backgroundTint">@color/tertiary_bg</item>
        <item name="android:padding">16dp</item>
    </style>
</resources>
