<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/secondary_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/media_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Now Playing Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/CardStyle"
            app:strokeWidth="0dp"
            android:layout_marginBottom="48dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F3B5;"
                    android:textSize="32sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/media_now_playing"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tv_now_playing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No media"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Transport Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="48dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_previous"
                style="@style/MediaButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="24dp"
                app:icon="@android:drawable/ic_media_previous"
                app:iconSize="32dp"
                app:iconTint="@color/primary_text"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_pause"
                style="@style/MediaButton"
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:icon="@android:drawable/ic_media_play"
                app:iconSize="48dp"
                app:iconTint="@color/accent_cyan"
                app:backgroundTint="@color/tertiary_bg"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                style="@style/MediaButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                app:icon="@android:drawable/ic_media_next"
                app:iconSize="32dp"
                app:iconTint="@color/primary_text"/>
        </LinearLayout>

        <!-- Volume Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/volume"
                    android:textSize="16sp"
                    android:textColor="@color/secondary_text"/>

                <TextView
                    android:id="@+id/tv_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textSize="16sp"
                    android:textColor="@color/accent_cyan"/>
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_volume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="80"
                app:trackColorActive="@color/accent_cyan"
                app:trackColorInactive="@color/divider"
                app:thumbColor="@color/accent_cyan"/>

            <!-- Mute Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mute"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                style="@style/SecondaryButton"
                android:text="@string/mute"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
