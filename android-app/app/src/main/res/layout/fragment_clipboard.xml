<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/secondary_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clipboard_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Auto Sync Toggle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/CardStyle"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_sync"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_auto_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/accent_cyan"
                    app:trackTint="@color/divider"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- From Desktop -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            style="@style/CardStyle"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/from_desktop"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_cyan"/>

                <TextView
                    android:id="@+id/tv_desktop_clipboard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/clipboard_empty"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginTop="12dp"
                    android:padding="12dp"
                    android:background="@color/trackpad_area"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_to_phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    style="@style/AccentButton"
                    android:text="@string/copy_to_phone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- From Phone -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            style="@style/CardStyle"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/from_phone"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_purple"/>

                <TextView
                    android:id="@+id/tv_phone_clipboard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/clipboard_empty"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginTop="12dp"
                    android:padding="12dp"
                    android:background="@color/trackpad_area"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_to_desktop"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    style="@style/AccentButton"
                    android:text="@string/copy_to_desktop"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_clipboard_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last synced: never"
            android:textSize="12sp"
            android:textColor="@color/disabled_text"
            android:gravity="center"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</LinearLayout>
